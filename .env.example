# ========================
# JayField - Environment Variables
# ========================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=JayField

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/jayfield?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@jayfield.com

# File Upload (UploadThing)
UPLOADTHING_SECRET=sk_xxxxxxxxxxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxxxxxx

# App Settings (overridable via admin dashboard)
DEFAULT_DP_PERCENTAGE=50
PAYMENT_DEADLINE_MINUTES=60
