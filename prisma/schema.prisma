generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  STAFF
  ADMIN
}

enum MemberTier {
  BRONZE
  SILVER
  GOLD
}

enum CourtType {
  INDOOR
  OUTDOOR
}

enum DayType {
  WEEKDAY
  WEEKEND
}

enum TimeType {
  REGULAR
  PRIME_TIME
}

enum BookingStatus {
  PENDING_PAYMENT
  PENDING_CONFIRMATION
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentType {
  DP
  FULL
  SETTLEMENT
}

enum PaymentStatus {
  PENDING
  UPLOADED
  CONFIRMED
  REJECTED
  EXPIRED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

enum NotificationType {
  BOOKING
  PAYMENT
  PROMO
  MEMBERSHIP
  SYSTEM
}

enum PointsType {
  EARNED_BOOKING
  EARNED_REVIEW
  EARNED_REFERRAL
  EARNED_BONUS
  REDEEMED_DISCOUNT
  REDEEMED_FREE_SESSION
  REDEEMED_MERCHANDISE
  ADMIN_ADJUST
}

enum PaymentMethodType {
  BANK_TRANSFER
  E_WALLET
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ==================== MODELS ====================

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?    @map("password_hash")
  name           String
  phone          String?
  avatarUrl      String?    @map("avatar_url")
  role           UserRole   @default(USER)
  tier           MemberTier @default(BRONZE)
  totalPoints    Int        @default(0) @map("total_points")
  totalBookings  Int        @default(0) @map("total_bookings")
  provider       String?
  providerId     String?    @map("provider_id")
  emailVerified  DateTime?  @map("email_verified")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  bookings          Booking[]
  recurringBookings RecurringBooking[]
  payments          Payment[]        @relation("ConfirmedBy")
  refunds           Refund[]         @relation("UserRefunds")
  processedRefunds  Refund[]         @relation("ProcessedBy")
  pointsHistory     PointsHistory[]
  notifications     Notification[]
  reviews           Review[]
  accounts          Account[]
  sessions          Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Location {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  phone        String?
  email        String?
  openTime     String   @default("08:00") @map("open_time")
  closeTime    String   @default("00:00") @map("close_time")
  thumbnailUrl String?  @map("thumbnail_url")
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  courts Court[]

  @@map("locations")
}

model Court {
  id         String    @id @default(cuid())
  locationId String    @map("location_id")
  name       String
  type       CourtType
  surface    String?
  capacity   Int       @default(10)
  facilities Json?
  photos     Json?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  location         Location          @relation(fields: [locationId], references: [id])
  pricing          Pricing[]
  bookings         Booking[]
  recurringBookings RecurringBooking[]
  reviews          Review[]

  @@map("courts")
}

model Pricing {
  id           String   @id @default(cuid())
  courtId      String   @map("court_id")
  dayType      DayType  @map("day_type")
  timeType     TimeType @map("time_type")
  startHour    String   @map("start_hour")
  endHour      String   @map("end_hour")
  pricePerHour Decimal  @map("price_per_hour") @db.Decimal(12, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  court Court @relation(fields: [courtId], references: [id])

  @@map("pricing")
}

model Booking {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  courtId       String        @map("court_id")
  bookingDate   DateTime      @map("booking_date") @db.Date
  startTime     String        @map("start_time")
  endTime       String        @map("end_time")
  durationHours Decimal       @map("duration_hours") @db.Decimal(3, 1)
  totalPrice    Decimal       @map("total_price") @db.Decimal(12, 2)
  dpAmount      Decimal?      @map("dp_amount") @db.Decimal(12, 2)
  paymentType   PaymentType   @map("payment_type")
  status        BookingStatus @default(PENDING_PAYMENT)
  notes         String?
  cancelledAt   DateTime?     @map("cancelled_at")
  cancelReason  String?       @map("cancel_reason")
  isRecurring   Boolean       @default(false) @map("is_recurring")
  recurringId   String?       @map("recurring_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  user             User              @relation(fields: [userId], references: [id])
  court            Court             @relation(fields: [courtId], references: [id])
  recurringBooking RecurringBooking? @relation(fields: [recurringId], references: [id])
  payments         Payment[]
  refunds          Refund[]
  review           Review?

  @@index([courtId, bookingDate, status])
  @@index([userId, status])
  @@map("bookings")
}

model RecurringBooking {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  courtId   String   @map("court_id")
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  court    Court     @relation(fields: [courtId], references: [id])
  bookings Booking[]

  @@map("recurring_bookings")
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @map("booking_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod String        @map("payment_method")
  paymentType   PaymentType   @map("payment_type")
  proofImageUrl String?       @map("proof_image_url")
  status        PaymentStatus @default(PENDING)
  confirmedById String?       @map("confirmed_by")
  confirmedAt   DateTime?     @map("confirmed_at")
  expiresAt     DateTime      @map("expires_at")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  booking     Booking  @relation(fields: [bookingId], references: [id])
  confirmedBy User?    @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  refunds     Refund[]

  @@map("payments")
}

model Refund {
  id               String       @id @default(cuid())
  paymentId        String       @map("payment_id")
  bookingId        String       @map("booking_id")
  userId           String       @map("user_id")
  amount           Decimal      @db.Decimal(12, 2)
  refundPercentage Int          @map("refund_percentage")
  reason           String
  status           RefundStatus @default(REQUESTED)
  bankName         String?      @map("bank_name")
  accountNumber    String?      @map("account_number")
  accountHolder    String?      @map("account_holder")
  processedById    String?      @map("processed_by")
  processedAt      DateTime?    @map("processed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  payment     Payment @relation(fields: [paymentId], references: [id])
  booking     Booking @relation(fields: [bookingId], references: [id])
  user        User    @relation("UserRefunds", fields: [userId], references: [id])
  processedBy User?   @relation("ProcessedBy", fields: [processedById], references: [id])

  @@map("refunds")
}

model PointsHistory {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  amount      Int
  type        PointsType
  description String?
  referenceId String?    @map("reference_id")
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("points_history")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  actionUrl String?          @map("action_url")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model Promo {
  id            String       @id @default(cuid())
  code          String       @unique
  title         String
  description   String?
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(12, 2)
  minBooking    Decimal?     @map("min_booking") @db.Decimal(12, 2)
  maxDiscount   Decimal?     @map("max_discount") @db.Decimal(12, 2)
  usageLimit    Int?         @map("usage_limit")
  usageCount    Int          @default(0) @map("usage_count")
  perUserLimit  Int          @default(1) @map("per_user_limit")
  memberOnly    Boolean      @default(false) @map("member_only")
  minTier       MemberTier?  @map("min_tier")
  startDate     DateTime     @map("start_date")
  endDate       DateTime     @map("end_date")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("promos")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  courtId   String   @map("court_id")
  bookingId String   @unique @map("booking_id")
  rating    Int
  comment   String?
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  court   Court   @relation(fields: [courtId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

model PaymentMethod {
  id            String            @id @default(cuid())
  name          String
  type          PaymentMethodType
  accountNumber String            @map("account_number")
  accountHolder String            @map("account_holder")
  logoUrl       String?           @map("logo_url")
  isActive      Boolean           @default(true) @map("is_active")
  sortOrder     Int               @default(0) @map("sort_order")
  createdAt     DateTime          @default(now()) @map("created_at")

  @@map("payment_methods")
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
